{
    "name": "laramago/laramago",
    "description": "Laravel compatibility preset and runner for Mago static analysis.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/gabrielrbarbosa/laramago",
    "keywords": [
        "laravel",
        "mago",
        "static-analysis",
        "larastan",
        "phpstan"
    ],
    "support": {
        "issues": "https://github.com/gabrielrbarbosa/laramago/issues",
        "source": "https://github.com/gabrielrbarbosa/laramago"
    },
    "require": {
        "php": "^8.3",
        "carthage-software/mago": "^1.29",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Laramago\\": "src/"
        }
    },
    "bin": [
        "bin/laramago"
    ],
    "scripts": {
        "ci": [
            "@check:composer",
            "@lint",
            "@test",
            "@static"
        ],
        "test": [
            "@php tests/run.php"
        ],
        "static": [
            "@php bin/laramago analyze --phpstan-level=6 --ignore-baseline --reporting-format=count"
        ],
        "check:composer": [
            "composer validate --strict"
        ],
        "lint": [
            "@php -l bin/laramago",
            "@php -l src/Application.php",
            "@php -l src/Concerns/BuildsLaravelFrameworkOverlays.php",
            "@php -l src/Concerns/BuildsLaravelModelOverlays.php",
            "@php -l src/Concerns/BuildsRuntimeConfig.php",
            "@php -l src/Concerns/BuildsSourceCompatibilityOverlays.php",
            "@php -l src/Concerns/MigratesPhpStan.php",
            "@php -l src/Concerns/RunsMagoProcesses.php",
            "@php -l resources/laravel-model-metadata.php",
            "@php -l tests/run.php",
            "@php -l tests/Support.php",
            "@php -l tests/CommandsTest.php",
            "@php -l tests/Stubs/LaravelModelMetadataFunctions.php",
            "@php -l tests/Overlays/PragmaAndHelperOverlaysTest.php",
            "@php -l tests/Overlays/DynamicMemberOverlaysTest.php",
            "@php -l tests/Overlays/ClassResolutionOverlaysTest.php",
            "@php -l tests/Overlays/LaravelMetadataAndFrameworkOverlaysTest.php"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
